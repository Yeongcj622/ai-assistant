# ── Groq (free, very fast — recommended) ─────────────────────────────────────
# Sign up free at https://console.groq.com → API Keys → Create API Key
# Free tier: generous rate limits, no credit card required
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile   # fastest+smartest; or: llama-3.1-8b-instant

# ── Ollama fallback (used when GROQ_API_KEY is not set) ──────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Optional ──────────────────────────────────────────────────────────────────
# ASSISTANT_WORKDIR=/home/you   # working directory for shell commands
